FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains 8;

method          simple;

simpleCoeffs
{
    n               (4 2 1);    // 4 in x, 2 in y, 1 in z
    delta           0.001;      // Small offset to avoid boundary alignment issues
}

distributed     no;

roots           ();
