FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      createPatchDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

pointSync false;

// List of patches to create or modify
patches
(
    {
        name            frontAndBack;

        patchInfo
        {
            type            empty;
        }

        constructFrom      patches;

        patches          (front back);
    }
);