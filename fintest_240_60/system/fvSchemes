FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;  // Better than Euler for stability
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;               // Never use 'default' for convection of scalars!

    div(phi,U)      Gauss linearUpwind grad(U);  // Keep for velocity (standard)
    div(phi,s)      bounded Gauss upwind;     
}
laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}


